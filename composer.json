{
    "name": "nyoncode/wire-core",
    "description": "Shared foundation for the Wire ecosystem – traits, actions, modals, notifications, icons, colors.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Ondřej Nyklíček",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "livewire/livewire": "^3.0",
        "nyoncode/laravel-package-toolkit": "^2.0.1"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "laravel/pint": "^1.29",
        "pestphp/pest": "^2.0|^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "NyonCode\\WireCore\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "NyonCode\\WireCore\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "NyonCode\\WireCore\\WireCoreServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
